{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "stringify1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          empId as short,",
				"          empName as string,",
				"          address as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 stringify(newcolumn = toString(empName) ? string,",
				"     format: 'json') ~> stringify1"
			]
		}
	}
}