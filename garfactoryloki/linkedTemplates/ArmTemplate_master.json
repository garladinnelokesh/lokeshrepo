{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "garfactoryloki"
		},
		"AzureDataLakeStorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage'"
		},
		"SqlServer1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServer1'"
		},
		"SqlServerbaserecommend_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServerbaserecommend'"
		},
		"AzureDataLakeStorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageloki123.dfs.core.windows.net/"
		},
		"SqlServer1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "@{linkedService().server_name}"
		},
		"SqlServer1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().data_name}"
		},
		"SqlServer1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "@{linkedService().user}"
		},
		"SqlServerbaserecommend_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "abccompany.database.windows.net"
		},
		"SqlServerbaserecommend_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "abcdfveb"
		},
		"SqlServerbaserecommend_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "loki"
		},
		"trigger_storage_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/19f3eb1a-444f-463f-afda-1d66feea5daf/resourceGroups/AzureFundamentals/providers/Microsoft.Storage/storageAccounts/storageloki123"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "garfactoryloki_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage_accountKey": {
						"value": "[parameters('AzureDataLakeStorage_accountKey')]"
					},
					"SqlServer1_password": {
						"value": "[parameters('SqlServer1_password')]"
					},
					"SqlServerbaserecommend_password": {
						"value": "[parameters('SqlServerbaserecommend_password')]"
					},
					"AzureDataLakeStorage_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage_properties_typeProperties_url')]"
					},
					"SqlServer1_properties_typeProperties_server": {
						"value": "[parameters('SqlServer1_properties_typeProperties_server')]"
					},
					"SqlServer1_properties_typeProperties_database": {
						"value": "[parameters('SqlServer1_properties_typeProperties_database')]"
					},
					"SqlServer1_properties_typeProperties_userName": {
						"value": "[parameters('SqlServer1_properties_typeProperties_userName')]"
					},
					"SqlServerbaserecommend_properties_typeProperties_server": {
						"value": "[parameters('SqlServerbaserecommend_properties_typeProperties_server')]"
					},
					"SqlServerbaserecommend_properties_typeProperties_database": {
						"value": "[parameters('SqlServerbaserecommend_properties_typeProperties_database')]"
					},
					"SqlServerbaserecommend_properties_typeProperties_userName": {
						"value": "[parameters('SqlServerbaserecommend_properties_typeProperties_userName')]"
					},
					"trigger_storage_properties_typeProperties_scope": {
						"value": "[parameters('trigger_storage_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}